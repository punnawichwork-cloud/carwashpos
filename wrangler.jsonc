{
  // Cloudflare Workers static-assets deploy for the Vite SPA build.
  // `npm run build` outputs ./dist, then `npx wrangler deploy` uploads it as
  // static assets. `single-page-application` serves index.html (200) for any
  // unknown path — the SPA fallback (replaces Pages' _redirects on Workers).
  "name": "carwashpos",
  "compatibility_date": "2024-09-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
